{
  "name": "claude-usage-monitor",
  "version": "2.1.6",
  "description": "Windows system tray app to monitor Claude AI usage limits",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && electron dist/main.js",
    "build": "tsc -p tsconfig.main.json && node build-renderer.js",
    "predist": "node -e \"require('fs').rmSync('dist-build', {recursive:true, force:true})\"",
    "dist": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:zip": "node scripts/zip-release.js",
    "release": "npm run dist && npm run dist:portable && node scripts/zip-release.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.claudeusage.monitor",
    "productName": "Claude Usage Monitor",
    "files": [
      "dist/**/*",
      "!dist/**/__tests__/**",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "directories": {
      "output": "dist-build"
    },
    "asar": false,
    "compression": "maximum",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "runAfterFinish": true
    }
  }
}
