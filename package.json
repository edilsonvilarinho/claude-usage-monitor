{
  "name": "claude-usage-monitor",
  "version": "15.0.0",
  "description": "Windows system tray app to monitor Claude AI usage limits",
  "author": {
    "name": "Edilson Vilarinho",
    "email": "edilson.vilarinho.messias@gmail.com"
  },
  "main": "dist/main.js",
  "workspaces": [
    "shared",
    "server"
  ],
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && electron --no-sandbox dist/main.js",
    "dev:build": "npm run build && npm run dev",
    "merge:to-master": "git push && git checkout master && git merge @{-1} && git push origin master && git branch -d @{-1} && git push origin --delete @{-1} && git checkout -",
    "build": "node build-renderer.js",
    "predist": "node -e \"require('fs').rmSync('dist-build', {recursive:true, force:true})\"",
    "dist": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:zip": "node scripts/zip-release.js",
    "dist:linux": "npm run build && electron-builder --linux",
    "release": "npm run dist && npm run dist:portable && node scripts/zip-release.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "shared:build": "npm run build --workspace=shared",
    "server:dev": "npm run dev --workspace=server",
    "server:build": "npm run build --workspace=server",
    "server:test": "npm run test --workspace=server"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "electron-store": "^8.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.claudeusage.monitor",
    "productName": "Claude Usage Monitor",
    "files": [
      "dist/**/*",
      "!dist/**/__tests__/**",
      "assets/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "assets/icon-linux.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "directories": {
      "output": "dist-build"
    },
    "asar": true,
    "compression": "maximum",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "runAfterFinish": true
    }
  }
}
