{
  "name": "@claude-usage/server",
  "version": "1.0.0",
  "private": true,
  "description": "Backend Hono para sincronização opcional do Claude Usage Monitor",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').copyFileSync('src/db/schema.sql','dist/db/schema.sql')\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@claude-usage/shared": "*",
    "@hono/node-server": "1.19.13",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "hono": "4.12.12",
    "jose": "^6.2.2",
    "pino": "^10.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsx": "4.21.0",
    "typescript": "^5.0.0"
  }
}
